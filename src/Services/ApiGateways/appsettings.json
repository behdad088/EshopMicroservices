{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Logger": {
    "elasticsearch": "http://localhost:9200"
  },
  "Certificates": {
    "CaPath": "../../certificates/ca.crt"
  },
  "ReverseProxy": {
    "Routes": {
      "c-short": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "c/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/c" },
          { "RequestHeader": "X-Forwarded-By", "Set": "yarp" }
        ]
      },
      "c-long": {
        "ClusterId": "catalog",
        "Match": {
          "Path": "catalog-api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/catalog-api" },
          { "RequestHeader": "X-Forwarded-By", "Set": "yarp" }
        ]
      },
      "b-short": {
        "ClusterId": "basket",
        "Match": {
          "Path": "b/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/b" },
          { "RequestHeader": "X-Forwarded-By", "Set": "yarp" }
        ]
      },
      "b-long": {
        "ClusterId": "basket",
        "Match": {
          "Path": "basket-api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/basket-api" },
          { "RequestHeader": "X-Forwarded-By", "Set": "yarp" }
        ]
      },
      "d-short": {
        "ClusterId": "discount",
        "Match": {
          "Path": "d/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/d" },
          { "RequestHeader": "X-Forwarded-By", "Set": "yarp" }
        ]
      },
      "d-long": {
        "ClusterId": "discount",
        "Match": {
          "Path": "discount-api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/discount-api" },
          { "RequestHeader": "X-Forwarded-By", "Set": "yarp" }
        ]
      },
      "oc-short": {
        "ClusterId": "order-command",
        "Match": {
          "Path": "oc/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/oc" },
          { "RequestHeader": "X-Forwarded-By", "Set": "yarp" }
        ]
      },
      "oc-long": {
        "ClusterId": "order-command",
        "Match": {
          "Path": "ordering-command-api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/ordering-command-api" },
          { "RequestHeader": "X-Forwarded-By", "Set": "yarp" }
        ]
      },
      "oq-short": {
        "ClusterId": "order-query",
        "Match": {
          "Path": "oq/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/oq" },
          { "RequestHeader": "X-Forwarded-By", "Set": "yarp" }
        ]
      },
      "oq-long": {
        "ClusterId": "order-query",
        "Match": {
          "Path": "ordering-query-api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/ordering-query-api" },
          { "RequestHeader": "X-Forwarded-By", "Set": "yarp" }
        ]
      },
      "i-short": {
        "ClusterId": "identity",
        "Match": {
          "Path": "i/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/i" },
          { "RequestHeader": "X-Forwarded-By", "Set": "yarp" }
        ]
      },
      "i-long": {
        "ClusterId": "identity",
        "Match": {
          "Path": "identity-api/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/identity-api" },
          { "RequestHeader": "X-Forwarded-By", "Set": "yarp" }
        ]
      }
    },
    "Clusters": {
      "catalog": {
        "Destinations": {
          "destination0": {
            "Address": "https://localhost:5050"
          }
        }
      },
      "basket": {
        "Destinations": {
          "destination0": {
            "Address": "https://localhost:5051"
          }
        }
      },
      "discount": {
        "Destinations": {
          "destination0": {
            "Address": "https://localhost:5052"
          }
        }
      },
      "identity": {
        "Destinations": {
          "destination0": {
            "Address": "https://localhost:5007"
          }
        }
      },
      "order-command": {
        "Destinations": {
          "destination0": {
            "Address": "https://localhost:5053"
          }
        }
      },
      "order-query": {
        "Destinations": {
          "destination0": {
            "Address": "https://localhost:5054"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}